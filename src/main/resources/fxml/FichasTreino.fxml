<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="900.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.academia.treino.ui.FichasTreinoController">
   <children>
      <Label text="Montagem de Fichas de Treino">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>
      
      <VBox spacing="10.0" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
         <children>
            <HBox spacing="15.0">
               <children>
                  <VBox prefWidth="250.0" spacing="5.0">
                     <children>
                        <Label text="1. Importar Template (Opcional):" textFill="#0066cc">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <ComboBox fx:id="comboTemplates" maxWidth="1.7976931348623157E308" promptText="Fichas Padrão da Academia" style="-fx-border-color: #0066cc; -fx-border-radius: 3;" />
                     </children>
                  </VBox>
                  <VBox prefWidth="200.0" spacing="5.0">
                     <children>
                        <Label text="Ou selecione um Aluno:" />
                        <ComboBox fx:id="comboAlunos" maxWidth="1.7976931348623157E308" promptText="Selecione o Aluno" />
                     </children>
                  </VBox>
                  <VBox prefWidth="200.0" spacing="5.0">
                     <children>
                        <Label text="Treinos Pessoais do Aluno:" />
                        <ComboBox fx:id="comboTreinosExistentes" maxWidth="1.7976931348623157E308" promptText="Editar Ficha Atual" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <HBox spacing="15.0">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Nome do Treino (Ex: Adaptação A):" />
                        <TextField fx:id="campoNomeTreino" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Objetivo (Ex: Hipertrofia):" />
                        <TextField fx:id="campoObjetivo" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>

      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox prefWidth="400.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label maxWidth="1.7976931348623157E308" text="Catálogo de Exercícios" HBox.hgrow="ALWAYS">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                     </children>
                  </HBox>
                  <TableView fx:id="tabelaCatalogo" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn prefWidth="150.0" text="Exercício">
                          <cellValueFactory><PropertyValueFactory property="nome" /></cellValueFactory>
                      </TableColumn>
                      <TableColumn prefWidth="120.0" text="Grupo Muscular">
                          <cellValueFactory><PropertyValueFactory property="grupoMuscular" /></cellValueFactory>
                      </TableColumn>
                    </columns>
                  </TableView>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#adicionarNaFicha" prefHeight="35.0" style="-fx-background-color: #5bc0de; -fx-text-fill: white; -fx-font-weight: bold;" text="Adicionar Exercício à Ficha ➡️" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clicouGeradorTreino" prefHeight="35.0" style="-fx-background-color: #ffc107; -fx-text-fill: black; -fx-font-weight: bold;" text="✨ Gerar Treino Automático" />
               </children>
            </VBox>

            <VBox prefWidth="550.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Ficha Selecionada">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
                  <TableView fx:id="tabelaFicha" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colunaExercicioFicha" prefWidth="120.0" text="Exercício" />
                      <TableColumn fx:id="colunaSeries" prefWidth="60.0" text="Séries" />
                      <TableColumn fx:id="colunaReps" prefWidth="60.0" text="Reps" />
                      <TableColumn fx:id="colunaCarga" prefWidth="80.0" text="Carga (kg)" />
                      <TableColumn fx:id="colunaDescanso" prefWidth="80.0" text="Pausa (s)" />
                    </columns>
                  </TableView>
                  
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#clicouNovoTreino" style="-fx-background-color: #8c8c8c; -fx-text-fill: white;" text="Limpar Tela" />
                        <Button mnemonicParsing="false" onAction="#clicouDuplicar" style="-fx-background-color: #f0ad4e; -fx-text-fill: white;" text="Copiar Treino" />
                        <Button mnemonicParsing="false" onAction="#removerDaFicha" style="-fx-background-color: #d9534f; -fx-text-fill: white;" text="Remover Item" />
                        
                        <HBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #e6f2ff; -fx-padding: 5; -fx-border-color: #b3d9ff; -fx-border-radius: 3;">
                           <children>
                              <CheckBox fx:id="checkFichaPadrao" mnemonicParsing="false" text="Salvar como Template Público" textFill="#0055a4">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </CheckBox>
                           </children>
                        </HBox>
                        
                        <Button mnemonicParsing="false" onAction="#salvarFichaCompleta" prefHeight="35.0" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold;" text="💾 Guardar Ficha" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
