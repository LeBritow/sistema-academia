<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.academia.treino.ui.ExerciciosController">
   <children>
      
      <VBox spacing="15.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Banco de Exercícios">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            
            <HBox spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#clicouNovo" prefHeight="35.0" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold;" text="Novo Exercício" />
                  <Button mnemonicParsing="false" onAction="#clicouEditar" prefHeight="35.0" style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-font-weight: bold;" text="Editar" />
                  <Button mnemonicParsing="false" onAction="#clicouExcluir" prefHeight="35.0" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold;" text="Excluir" />
               </children>
            </HBox>
            
            <TableView fx:id="tabelaExercicios" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn prefWidth="180.0" text="Nome">
                    <cellValueFactory><PropertyValueFactory property="nome" /></cellValueFactory>
                </TableColumn>
                <TableColumn prefWidth="140.0" text="Grupo Muscular">
                    <cellValueFactory><PropertyValueFactory property="grupoMuscular" /></cellValueFactory>
                </TableColumn>
              </columns>
            </TableView>
         </children>
      </VBox>
      
      <VBox prefWidth="300.0" spacing="15.0" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #f9f9f9;">
         <children>
            <Label text="Demonstração">
               <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            
            <Label fx:id="lblNomeExercicio" text="Selecione um exercício" wrapText="true">
               <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            
            <VBox alignment="CENTER" prefHeight="200.0" style="-fx-border-color: #ddd; -fx-background-color: #eee;">
               <children>
                  <ImageView fx:id="imgPreview" fitHeight="190.0" fitWidth="260.0" pickOnBounds="true" preserveRatio="true" />
               </children>
            </VBox>
            
            <Label text="Orientação Técnica:">
               <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <Label fx:id="lblDescricao" text="A descrição e os detalhes de execução vão aparecer aqui." textFill="#555555" wrapText="true" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      
   </children>
</HBox>